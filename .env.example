# TP-Link cloud credentials, required for newer SMART-protocol Kasa devices
# (e.g. KP125M) which authenticate before discovery/control. Legacy plugs work
# without these. Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
TPLINK_USERNAME=
TPLINK_PASSWORD=
