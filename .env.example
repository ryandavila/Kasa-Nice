# TP-Link cloud credentials, required for newer SMART-protocol Kasa devices
# (e.g. KP125M) which authenticate before discovery/control. Legacy plugs work
# without these. Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
TPLINK_USERNAME=
TPLINK_PASSWORD=

# Optional: a CIDR subnet the server sweeps by unicast on startup and offers as
# the default in the Discovery tab. Use this when your plugs live on a separate
# subnet/VLAN that broadcast discovery can't reach (e.g. an isolated IoT VLAN).
# Leave blank to rely on broadcast + manually-added hosts only.
KASA_SCAN_SUBNET=
